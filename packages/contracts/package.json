{
  "name": "@helix/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Shared API, event, schema, and state-machine contracts shell.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "yarn run build && vitest run --passWithNoTests --config ../../vitest.config.ts --dir .",
    "lint": "eslint . --max-warnings 0 --ignore-pattern dist/** --no-warn-ignored"
  },
  "type": "module",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
