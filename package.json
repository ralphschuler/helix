{
  "name": "helix",
  "version": "0.0.0",
  "private": true,
  "description": "Durable distributed execution platform monorepo.",
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "check": "yarn workspaces foreach -A run check",
    "test": "yarn workspaces foreach -A run test",
    "lint": "yarn workspaces foreach -A run lint",
    "docs:check": "node scripts/check-docs.mjs",
    "tooling:check": "node scripts/check-validation-tooling.mjs",
    "infra:smoke": "node scripts/infra-smoke.mjs",
    "validate": "yarn run docs:check && yarn run tooling:check && yarn run check && yarn run test && yarn run lint"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "22",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}
